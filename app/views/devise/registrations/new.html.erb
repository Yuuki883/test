<div class="col-md-12 text-center">
    <div class="modal-dialog" style="margin-bottom:0">
        <div class="modal-content">
            <br>
            <div class="mx-auto">
                <div class="panel-heading">
                    <h3 class="panel-title">新規登録</h3>
                </div>
            </div>
            <br>
            <div class="panel-body">
                <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
                <%= render "devise/shared/error_messages", resource: resource %>
                <form role="form">
                    <fieldset>
                        <div class="form-group">
                            <%= f.text_field :name, autofoÏcus: true, autocomplete: "name", class:
                            "form-control", placeholder: "ユーザーネーム" %>
                        </div>
                        <div class="form-group">
                            <div class="field">
                                <%= f.email_field :email, autofocus: true, autocomplete: "email", class:
                                "form-control", placeholder: "Eメール" %>
                            </div>
                        </div>
                        <div class="form-group">
                            <%= f.password_field :password, autocomplete: "current-password" , class:
                            "form-control", placeholder: "パスワード" %>
                        </div>
                        <div class="form-group">
                            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                            class:"form-control", placeholder: "パスワードの確認" %>
                        </div>
                        <div class="actions">
                            <%= f.submit "登録", class:"btn info"%>
                        </div>
                    </fieldset>
                </form>
                <% end %>
            </div>
        </div>
    </div>
</div>