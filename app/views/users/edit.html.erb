  <body>
    <strong class="text-center">
        <% if flash[:notice] %>
            <p class="alert alert-success"><%= flash[:notice] %></p>
        <% end %>
    </strong>
    <br>
    <div class="col-md7">
        <h1 class="text-align: text-center">
        プロフィール編集
        </h1>
        <br>
      <%= form_with model:@user, local: true do |f| %>
      <div class="row no-gutters">
          <div class="card bg-light mx-auto">
              <div class="card-body">
                  <table class="table md-0 table-responsive text-nowrap">
                      <th>プロフィール画像</th>
                      <td>
                          <%= attachment_image_tag @user, :image, :fill, 200, 200, class: "rounded-circle", fallback: "no_image.jpg", size:'200x200'%><br>
                          <%= f.attachment_field :image %>
                      </td>
                      <tr>
                          <th>ユーザー名</th>
                          <td><%= f.text_field :name %></td>
                      </tr>
                      <tr>
                          <th>自己紹介</th>
                          <td><%= f.text_area :introduce, size: "50x5" %></td>
                      </tr>
                  </table>
                  <div class="text-center">
                      <%= f.submit '変更を保存する', class:"btn btn-primary btn-lg" %>
                  </div>
              </div>
          </div>
        <% end %>
      </div>
    </div>
  </body>
</html>