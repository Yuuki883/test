<br>
<div class="container-fluid text-center">
    <div class="row-fluid">
        <div class="span2">
            <%= attachment_image_tag user, :image, :fill, 200, 200, class:
            "rounded-circle", fallback: "no_image.jpg", size:'200x200' %>
        </div>
        <div class="span8">
            <h3><%= user.name%></h3>
            <% if user.introduce.blank? %>
                <h6>まだ自己紹介はありません</h6>
            <% else%>
                <h6><%= user.introduce%></h6>
            <% end %>
        </div>
        <div class="span2">
            <div class="btn-group">
                <% if @user.id == current_user.id %>
                    <div class="setting">
                        <%= link_to "プロフィールの編集" , edit_user_path, class:"fas fa-cog"%>
                    </div>
                <% end %>
            </div>
        </div>
    </div>
  <br>
  <h2 class="text-center">
      作成した掲示板</h2>
  <% if @topics.count > 0 %>
  <table class='table text-center'>
    <thead>
      <tr>
        <th>タイトル</th>
        <th>コメント数</th>
      </tr>
    </thead>
    <tbody>
      <% @topics.each do |topic| %>
      <tr class="table-primary">
        <td><strong><%= link_to topic.title, topic_path(topic.id) %><strong></td>
        <td><%= topic.topic_comments.count %></td>
      </tr>
      <% end %>
    </tbody>
  </table>
  <div class="row">
    <div class="mx-auto">
      <%= paginate @topics %>
    </div>
  </div>
  <% else %>
  <div class="mx-auto">
    <%= link_to "掲示板を作成する", new_topic_path, class:"btn btn-primary btn-lg"%>
    <% end %>
  </div>
</div>